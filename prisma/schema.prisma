// Prisma schema — Coworking ERP (PATCH v2: cabins, employee directory, vendor invoice OCR, blacklist, half-price seats)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============= USERS & AUTH =============
model User {
  id            String   @id @default(cuid())
  emp_id        String?  @unique
  email         String   @unique
  name          String
  passwordHash  String
  role          String   // ADMIN | OWNER | MANAGER | SALES | OPS | CENTER_MANAGER | ACCOUNTS | IT | CLIENT
  centerId      String?
  center        Center?  @relation(fields: [centerId], references: [id])

  // CLIENT users — link to employer Client (for employee directory)
  employerClientId String?
  employerClient   Client?  @relation("ClientEmployees", fields: [employerClientId], references: [id])
  aadhaar          String?
  pan              String?
  designation      String?

  phone         String?
  active        Boolean  @default(true)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leadsOwned        Lead[]        @relation("LeadOwner")
  proposalsCreated  Proposal[]    @relation("ProposalCreator")
  proposalsApproved Proposal[]    @relation("ProposalApprover")
  prsRaised         PurchaseRequest[]
  posIssued         PurchaseOrder[]
  comments          Comment[]
  commentEdits      CommentEdit[]
  attendance        AttendanceLog[]
  tickets           Ticket[]
  bookings          Booking[]
  picOf             Client[]       @relation("ClientPIC")
  staffAttendance   StaffAttendance[]
  leavesRequested   LeaveRequest[]    @relation("LeaveRequester")
  leavesDecided     LeaveRequest[]    @relation("LeaveDecider")
  auditLogs         AuditLog[]

  // Occupancy module
  allocationsMade   Allocation[]
  reservationsMade  Reservation[]

  passwordResets    ClientInvite[] @relation("UserResets")
}

// ============= CENTERS =============
model Center {
  id                String   @id @default(cuid())
  name              String
  city              String
  address           String?
  totalSeats        Int      @default(0)
  mapImagePath      String?  @db.Text // digital floor map
  commonAreaPhotos  String?  @db.Text // JSON array of file paths
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())

  users         User[]
  leads         Lead[]
  visitors      Visitor[]
  proposals     Proposal[]
  clients       Client[]
  prs           PurchaseRequest[]
  pos           PurchaseOrder[]
  inventory     InventoryItem[]
  assets        Asset[]
  repairs       Repair[]
  bookings      Booking[]
  meetingRooms  MeetingRoom[]
  notices       Notice[]
  attendance    AttendanceLog[]
  expenses      Expense[]
  invoices      ClientInvoice[]
  cabins        Cabin[]
  seats         Seat[]
  staffAttendance StaffAttendance[]

  // Occupancy module
  floors        Floor[]
  zones         Zone[]
  spaces        Space[]
}

// ============= CABINS (NEW) =============
// A center is divided into cabins (e.g., 6-seater) + open seats. The seat map renders these.
model Cabin {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  floorId     String?
  floor       Floor?   @relation(fields: [floorId], references: [id])
  name        String   // e.g., "Cabin A1"
  capacity    Int      // seats inside the cabin
  photos      String?  @db.Text // JSON array of file paths
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  seats       Seat[]
  proposals   Proposal[]
  clients     Client[]
  spaces      Space[]   // occupancy module bridge
}

// ============= CRM: LEADS =============
model Lead {
  id            String    @id @default(cuid())
  source        String
  name          String
  email         String?
  phone         String?
  company       String?
  seatsNeeded   Int?
  budget        Float?
  notes         String?  @db.Text
  status        String    @default("Lead")
  ownerId       String?
  owner         User?     @relation("LeadOwner", fields: [ownerId], references: [id])
  centerId      String?
  center        Center?   @relation(fields: [centerId], references: [id])

  // Channel partner this lead came through (Broker / Agent / IPC).
  sourceType        String?         // "Broker" | "Agent" | "IPC"
  partnerContactId  String?
  partnerContact    PartnerContact? @relation(fields: [partnerContactId], references: [id])

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  comments      Comment[]
  visitors      Visitor[]
  proposals     Proposal[]
}

// A channel partner FIRM: a Broker / Agent / IPC organisation. Holds many contact people.
model Partner {
  id            String           @id @default(cuid())
  type          String           // "Broker" | "Agent" | "IPC"
  organisation  String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  contacts      PartnerContact[]

  @@unique([type, organisation])
}

// A contact person belonging to a Partner firm.
model PartnerContact {
  id            String   @id @default(cuid())
  partnerId     String
  partner       Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  name          String
  phone         String?
  email         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         Lead[]
}

model Comment {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  channel   String
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  // Edit tracking: who/when the current body was last changed; full prior versions in CommentEdit.
  editedAt   DateTime?
  editedById String?
  edits      CommentEdit[]
}

// Immutable audit log: one row per edit of a Comment, storing the body it had BEFORE that edit.
model CommentEdit {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  prevBody  String   @db.Text
  editorId  String?
  editor    User?    @relation(fields: [editorId], references: [id])
  createdAt DateTime @default(now())
}

// ============= VISITORS / KYC =============
model Visitor {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  email         String?
  aadhaar       String?
  pan           String?
  kycVerified   Boolean  @default(false)
  digilockerRef String?
  tourTaken     Boolean  @default(false)
  tourDate      DateTime?
  leadId        String?
  lead          Lead?    @relation(fields: [leadId], references: [id])
  centerId      String?
  center        Center?  @relation(fields: [centerId], references: [id])
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
}

// ============= PROPOSALS =============
model Proposal {
  id              String   @id @default(cuid())
  leadId          String?
  lead            Lead?    @relation(fields: [leadId], references: [id])
  centerId        String
  center          Center   @relation(fields: [centerId], references: [id])
  cabinId         String?
  cabin           Cabin?   @relation(fields: [cabinId], references: [id])
  quotedPrice     Float
  negotiatedPrice Float
  securityDeposit Float
  lockInMonths    Int
  customisations  String?  @db.Text
  imagesJson      String?  @db.Text // auto-populated from cabin + center common area on send
  pdfSnapshot     String?  // public path of the last edited+saved proposal document (HTML)
  status          String   @default("DRAFT")
  belowThreshold  Boolean  @default(false)
  approverNotes   String?
  createdById     String
  createdBy       User     @relation("ProposalCreator", fields: [createdById], references: [id])
  approvedById    String?
  approvedBy      User?    @relation("ProposalApprover", fields: [approvedById], references: [id])
  sentAt          DateTime?
  acceptedAt      DateTime?
  acceptanceFile  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client?
}

// ============= CLIENTS / ONBOARDING / CONTRACTS =============
model Client {
  id                String    @id @default(cuid())
  companyName       String
  contactName       String
  email             String
  phone             String?
  centerId          String
  center            Center    @relation(fields: [centerId], references: [id])
  cabinId           String?
  cabin             Cabin?    @relation(fields: [cabinId], references: [id])
  proposalId        String?   @unique
  proposal          Proposal? @relation(fields: [proposalId], references: [id])
  startDate         DateTime?
  specialAgreement  String?
  sentToOps         Boolean   @default(false)
  cmConfirmed       Boolean   @default(false)
  clientConfirmed   Boolean   @default(false)
  active            Boolean   @default(true)
  occupiedSeats     Int       @default(0)   // how many seats client is actually using
  totalCabinSeats   Int       @default(0)   // capacity of cabin/center taken
  unusedSeatReminderSent Boolean @default(false)
  unusedSeatLastReminderAt DateTime?
  picUserId         String?                  // Person In Charge (User.id)
  pic               User?     @relation("ClientPIC", fields: [picUserId], references: [id])
  createdAt         DateTime  @default(now())

  contract          Contract?
  invoices          ClientInvoice[]
  tickets           Ticket[]
  feedback          Feedback[]
  bookings          Booking[]
  referralsMade     Referral[] @relation("ReferralMadeBy")
  referralsReceived Referral[] @relation("ReferralFor")
  employees         User[]     @relation("ClientEmployees")
  invites           ClientInvite[] @relation("ClientInvites")

  // Occupancy module
  allocations       Allocation[]
}

model Contract {
  id              String   @id @default(cuid())
  clientId        String   @unique
  client          Client   @relation(fields: [clientId], references: [id])
  startDate       DateTime
  endDate         DateTime?
  monthlyRent     Float
  securityDeposit Float
  incrementPct    Float
  revisionDate    DateTime
  reminderSent    Boolean  @default(false)
  filePath        String?  // uploaded existing contract
  ocrParsedJson   String?  @db.Text // OCR result (renew date, terms etc.)
  createdAt       DateTime @default(now())

  allocations     Allocation[]   // occupancy module
}

// ============= VENDORS / PROCUREMENT =============
model Vendor {
  id            String   @id @default(cuid())
  name          String
  category      String
  contact       String?
  email         String?
  phone         String?
  gstin         String?
  panNumber     String?
  bankDetails   String?
  active        Boolean  @default(true)
  blacklisted   Boolean  @default(false)
  blacklistRemarks String?
  deletedAt     DateTime?
  rateCardJson  String?  @db.Text
  createdAt     DateTime @default(now())

  pos          PurchaseOrder[]
  invoices     VendorInvoice[]
}

model PurchaseRequest {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id])
  raisedById  String
  raisedBy    User     @relation(fields: [raisedById], references: [id])
  itemsJson   String
  reason      String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())

  pos         PurchaseOrder[]
}

model PurchaseOrder {
  id              String   @id @default(cuid())
  poNumber        String   @unique @default(cuid())
  prId            String?
  pr              PurchaseRequest? @relation(fields: [prId], references: [id])
  vendorId        String
  vendor          Vendor   @relation(fields: [vendorId], references: [id])
  centerId        String
  center          Center   @relation(fields: [centerId], references: [id])
  issuedById      String
  issuedBy        User     @relation(fields: [issuedById], references: [id])
  itemsJson       String
  totalAmount     Float
  isRecurring     Boolean  @default(false)
  recurrence      String?
  category        String
  piFile          String?
  invoiceFile     String?
  paymentStatus   String   @default("UNPAID")
  deliveryConfirmed Boolean @default(false)
  deliveryNotes   String?
  deliveryPhotos  String?
  createdAt       DateTime @default(now())

  vendorInvoices  VendorInvoice[]
}

// ============= VENDOR INVOICES (NEW — upload, OCR, PO match, approve) =============
model VendorInvoice {
  id           String   @id @default(cuid())
  vendorId     String
  vendor       Vendor   @relation(fields: [vendorId], references: [id])
  poId         String?
  po           PurchaseOrder? @relation(fields: [poId], references: [id])
  filePath     String   // uploaded invoice
  ocrJson      String?  @db.Text  // OCR-parsed fields (invoice no, amount, gst, date, po ref)
  invoiceNo    String?
  invoiceDate  DateTime?
  amount       Float    @default(0)
  gst          Float    @default(0)
  poMatchStatus String  @default("UNMATCHED") // UNMATCHED | MATCHED | MISMATCH
  status       String   @default("PENDING")    // PENDING | APPROVED | REJECTED | BOOKED
  approvedById String?
  remarks      String?  @db.Text
  createdAt    DateTime @default(now())
}

// ============= INVENTORY & ASSETS =============
model InventoryItem {
  id            String   @id @default(cuid())
  centerId      String
  center        Center   @relation(fields: [centerId], references: [id])
  name          String
  category      String
  unit          String
  currentStock Float    @default(0)
  threshold     Float    @default(0)
  consumptionLog String?
  updatedAt     DateTime @updatedAt
}

model Asset {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id])
  name        String
  category    String
  serialNo    String?
  location    String?
  purchaseDate DateTime?
  cost        Float?
  status      String   @default("OK")
  createdAt   DateTime @default(now())
}

// ============= REPAIRS =============
model RepairCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Repair {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id])
  category    String
  description String
  reportedBy  String?
  assignedTo  String
  vendorId    String?
  cost        Float?
  status      String   @default("OPEN")
  photos      String?  @db.Text
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
}

// ============= MEETING ROOMS / BOOKINGS =============
model MeetingRoom {
  id        String   @id @default(cuid())
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id])
  name      String
  capacity  Int
  hourlyRate Float   @default(0)
  amenities String?  @db.Text // JSON array of amenity strings e.g. ["Projector","Whiteboard","AC"]
  active    Boolean  @default(true)

  bookings  Booking[]
  spaces    Space[]   // occupancy module bridge
}

model Booking {
  id        String   @id @default(cuid())
  roomId    String
  room      MeetingRoom @relation(fields: [roomId], references: [id])
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id])
  bookedById String
  bookedBy  User     @relation(fields: [bookedById], references: [id])
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  startTime DateTime
  endTime   DateTime
  durationHrs Float    @default(0)
  isChargeable Boolean @default(false)   // true if this booking is past quota
  chargedAmount Float  @default(0)
  notes         String?  @db.Text
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())
}

// ============= CLIENT INVOICES =============
model ClientInvoice {
  id           String   @id @default(cuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id])
  centerId     String
  center       Center   @relation(fields: [centerId], references: [id])
  invoiceNo    String   @unique
  periodStart  DateTime
  periodEnd    DateTime
  baseAmount   Float
  halfPriceLine Float   @default(0)   // unused-seat half-price portion
  meetingRoomLine Float @default(0)   // overage charges
  gstAmount    Float    @default(0)
  totalAmount  Float
  status       String   @default("ISSUED")
  issuedAt     DateTime @default(now())
  paidAt       DateTime?
  emailSent    Boolean  @default(false)
}

// ============= CLIENT PORTAL =============
model Ticket {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  raisedById String?
  raisedBy  User?    @relation(fields: [raisedById], references: [id])
  category  String
  subject   String
  body      String
  status    String   @default("OPEN")
  createdAt DateTime @default(now())
}

model Feedback {
  id        String   @id @default(cuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id])
  rating    Int
  body      String?  @db.Text
  createdAt DateTime @default(now())
}

model Notice {
  id        String   @id @default(cuid())
  centerId  String?
  center    Center?  @relation(fields: [centerId], references: [id])
  title     String
  body      String
  isAd      Boolean  @default(false)
  brand     String?
  startDate DateTime @default(now())
  endDate   DateTime?
  createdAt DateTime @default(now())
}

// ============= REFERRALS =============
model Referral {
  id            String   @id @default(cuid())
  referrerType  String
  referrerId    String?
  referrer      Client?  @relation("ReferralMadeBy", fields: [referrerId], references: [id])
  referrerName  String
  contact       String?
  prospectName  String
  prospectPhone String?
  converted     Boolean  @default(false)
  convertedClientId String?
  convertedClient Client? @relation("ReferralFor", fields: [convertedClientId], references: [id])
  feeAmount     Float    @default(0)
  feePaid       Boolean  @default(false)
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
}

// ============= ACCOUNTS / EXPENSES / LEDGER =============
model Expense {
  id        String   @id @default(cuid())
  centerId  String?
  center    Center?  @relation(fields: [centerId], references: [id])
  category  String
  amount    Float
  gst       Float    @default(0)
  tds       Float    @default(0)
  payee     String
  paymentMode String
  date      DateTime @default(now())
  notes         String?  @db.Text
  attachment String?
}

model LedgerEntry {
  id        String   @id @default(cuid())
  account   String
  debit     Float    @default(0)
  credit    Float    @default(0)
  refType   String
  refId     String?
  centerId  String?
  date      DateTime @default(now())
  narration String?
}

// ============= ATTENDANCE & SOPs =============
model AttendanceLog {
  id          String   @id @default(cuid())
  centerId    String
  center      Center   @relation(fields: [centerId], references: [id])
  reportedById String
  reportedBy  User     @relation(fields: [reportedById], references: [id])
  date        DateTime @default(now())
  cleanliness String
  issuesNote  String?  @db.Text
  photos      String?  @db.Text
}

model Sop {
  id        String   @id @default(cuid())
  title     String
  body      String
  category  String
  fileUrl   String?
  createdAt DateTime @default(now())
}

// ============= LEAVE MANAGEMENT =============
model LeaveRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation("LeaveRequester", fields: [userId], references: [id])
  startDate   DateTime  // midnight (server local) of first leave day
  endDate     DateTime  // midnight (server local) of last leave day (inclusive)
  type        String    // CASUAL | SICK | PAID | UNPAID | OTHER
  reason      String?
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED
  decidedById String?
  decidedBy   User?     @relation("LeaveDecider", fields: [decidedById], references: [id])
  decidedAt   DateTime?
  notes         String?  @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============= STAFF ATTENDANCE (personal check-in / check-out) =============
model StaffAttendance {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  date        DateTime  // midnight (server local) of the day
  checkInAt   DateTime?
  checkOutAt  DateTime?
  centerId    String?
  center      Center?   @relation(fields: [centerId], references: [id])
  status      String    @default("PRESENT") // PRESENT | LATE | HALF_DAY | LEAVE | HOLIDAY | ABSENT
  notes         String?  @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, date])
}

// ============= AUDIT LOG =============
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. CLIENT_CREATED, INVOICE_SENT, PROPOSAL_APPROVED
  targetType String?  // e.g. Client, Proposal, Invoice
  targetId   String?
  meta       String?  @db.Text // JSON string for extra context
  createdAt  DateTime @default(now())
}

// ============= CLIENT INVITES / PASSWORD RESET =============
// Single token store for two flows (distinguished by `type`):
//   INVITE — admin/CM invites a client contact; recipient sets name + password to create a CLIENT user.
//   RESET  — a client requests a password reset; recipient sets a new password.
model ClientInvite {
  id               String    @id @default(cuid())
  token            String    @unique
  type             String    @default("INVITE") // INVITE | RESET
  email            String
  // INVITE: the employer Client the new user will belong to.
  employerClientId String?
  employerClient   Client?   @relation("ClientInvites", fields: [employerClientId], references: [id])
  // RESET: the existing user whose password is being reset.
  userId           String?
  user             User?     @relation("UserResets", fields: [userId], references: [id])
  invitedById      String?   // staff user who generated an INVITE
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime  @default(now())

  @@index([email])
  @@index([employerClientId])
  @@index([expiresAt, usedAt])
}

// ============= SEAT MAP =============
model Seat {
  id            String   @id @default(cuid())
  centerId      String
  center        Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  cabinId       String?
  cabin         Cabin?   @relation(fields: [cabinId], references: [id])
  number        String
  zone          String?
  assignedClientId String?
  occupied      Boolean  @default(false)
  partialOccupancy Boolean @default(false)  // true = orange (client took cabin but not this seat)
  createdAt     DateTime @default(now())

  spaces        Space[]  // occupancy module bridge

  @@unique([centerId, number])
}

// ============= OCCUPANCY MODULE =============
// Additive layer over Center/Cabin/Seat/MeetingRoom. Space is the unified occupancy unit;
// it bridges back to the existing Seat/Cabin/MeetingRoom rows via optional FKs so the current
// seatmap/bookings keep working. Status here is kept in sync with Seat.occupied (see lib/occupancy).

enum SpaceType {
  DEDICATED_SEAT
  HOT_DESK
  CABIN
  MEETING_ROOM
  PRIVATE_OFFICE
  VIRTUAL_OFFICE
}

enum SpaceStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  MAINTENANCE
  BLOCKED
}

enum AllocationStatus {
  ACTIVE
  EXPIRED
  TERMINATED
  TRANSFERRED
}

model Floor {
  id        String   @id @default(cuid())
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  name      String          // "Ground", "1st Floor"
  level     Int             // 0,1,2 … for ordering
  planImages String? @db.Text // JSON array of floor-plan image paths (at least one required)
  createdAt DateTime @default(now())

  zones     Zone[]
  spaces    Space[]
  cabins    Cabin[]

  @@unique([centerId, level])
  @@index([centerId])
}

model Zone {
  id        String   @id @default(cuid())
  centerId  String
  center    Center   @relation(fields: [centerId], references: [id], onDelete: Cascade)
  floorId   String?
  floor     Floor?   @relation(fields: [floorId], references: [id])
  name      String          // "North Wing", "Quiet Zone"
  createdAt DateTime @default(now())

  spaces    Space[]

  @@index([centerId])
  @@index([floorId])
}

model Space {
  id        String      @id @default(cuid())
  code      String                       // human code e.g. "F2-Z1-S05"
  name      String
  type      SpaceType
  capacity  Int         @default(1)
  status    SpaceStatus @default(AVAILABLE)

  centerId  String
  center    Center      @relation(fields: [centerId], references: [id], onDelete: Cascade)
  floorId   String?
  floor     Floor?      @relation(fields: [floorId], references: [id])
  zoneId    String?
  zone      Zone?       @relation(fields: [zoneId], references: [id])

  // Optional bridges to existing models (one set per Space, depending on type)
  cabinId       String?
  cabin         Cabin?       @relation(fields: [cabinId], references: [id])
  seatId        String?
  seat          Seat?        @relation(fields: [seatId], references: [id])
  meetingRoomId String?
  meetingRoom   MeetingRoom? @relation(fields: [meetingRoomId], references: [id])

  // visual map coordinates (occupancy map view)
  gridX     Int?
  gridY     Int?

  deletedAt DateTime?                     // soft delete only
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  allocations  Allocation[]
  reservations Reservation[]
  transfers    SpaceTransfer[]

  @@unique([centerId, code])
  @@index([centerId, status])
  @@index([floorId])
  @@index([zoneId])
  @@index([type, status])
}

model Allocation {
  id            String  @id @default(cuid())
  spaceId       String
  space         Space   @relation(fields: [spaceId], references: [id])
  clientId      String
  client        Client  @relation(fields: [clientId], references: [id])
  contractId    String?                       // reuse Contract as the agreement
  contract      Contract? @relation(fields: [contractId], references: [id])

  seatsTaken    Int      @default(1)          // partial cabin/floor allocation
  startDate     DateTime
  endDate       DateTime?
  status        AllocationStatus @default(ACTIVE)

  allocatedById String
  allocatedBy   User     @relation(fields: [allocatedById], references: [id])

  deletedAt     DateTime?                      // soft delete only
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  history       OccupancyHistory[]

  @@index([clientId])
  @@index([spaceId, status])
  @@index([status, endDate])                   // expiring-soon queries
}

// Append-only ledger. NEVER updated or deleted — one row per occupancy event.
model OccupancyHistory {
  id            String      @id @default(cuid())
  allocationId  String?
  allocation    Allocation? @relation(fields: [allocationId], references: [id])
  spaceId       String
  clientId      String?
  prevClientId  String?                        // for transfers
  event         String                         // ALLOCATED|RELEASED|TRANSFERRED|EXPIRED|RESERVED|RESERVATION_EXPIRED
  startDate     DateTime?
  endDate       DateTime?
  vacatedAt     DateTime?
  actorId       String?
  meta          String?     @db.Text           // JSON snapshot
  createdAt     DateTime    @default(now())

  @@index([spaceId])
  @@index([clientId])
  @@index([allocationId])
}

model Reservation {
  id           String   @id @default(cuid())
  spaceId      String
  space        Space    @relation(fields: [spaceId], references: [id])
  reservedById String
  reservedBy   User     @relation(fields: [reservedById], references: [id])
  clientId     String?                          // optional held-for client
  reservedAt   DateTime @default(now())
  expiresAt    DateTime
  released     Boolean  @default(false)         // cron sets true on expiry/consumption
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([expiresAt, released])                // cron sweep
  @@index([spaceId])
}

model SpaceTransfer {
  id               String   @id @default(cuid())
  spaceId          String
  space            Space    @relation(fields: [spaceId], references: [id])
  fromClientId     String?
  toClientId       String?
  fromAllocationId String?
  toAllocationId   String?
  batchId          String?                       // groups a bulk transfer
  transferredById  String
  reason           String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([batchId])
  @@index([spaceId])
}
